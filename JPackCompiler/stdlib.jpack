namespace World {
    // setBlock, fill, fillbiome, clone, border, data (block, block entity), forceload, gamerule, item (block entities)
    // locate, loot, place, seed, time, weather, particle

    @intrinsic
    void setBlock(int x, int y, int z, string block) {
        @cmd "setblock {x} {y} {z} {block}";
    }
    
    @intrinsic
    void fill(int x1, int y1, int z1, int x2, int y2, int z2, string block) {
        @cmd "fill {x1} {y1} {z1} {x2} {y2} {z2} {block}";
    }
    
    @intrinsic
    void setBlockMode(int x, int y, int z, string block, string mode) {
        @cmd "setblock {x} {y} {z} {block} {mode}";
    }
    
    @intrinsic
    void addBorderDistance(float distance) {
        @cmd "worldborder add {distance}";
    }
    
    @intrinsic
    void addBorderDistanceOverTime(float distance, int time) {
        @cmd "worldborder add {distance} {time}";
    }
    
    @intrinsic
    void setBorderDistance(float distance) {
        @cmd "worldborder set {distance}";
    }
    
    @intrinsic
    void setBorderDistanceOverTime(float distance, int time) {
        @cmd "worldborder set {distance} {time}";
    }
    
    @intrinsic
    void setBorderCenter(int x, int z) {
        @cmd "worldborder center {x} {z}";
    }
    
    //@intrinsic
    //@returns_command
    //int getBorderDistance() {
    //    @cmd "worldborder get";
    //}
    
    @intrinsic
    @store_result_intrinsic  
    int blockMatches(int x, int y, int z, string block) {
        @cmd "execute store result storage {__ns}:return value int 1 if block {x} {y} {z} {block}";
    }
    
    @intrinsic
    void placeStructure(string structure, int x, int y, int z) {
        @cmd "place structure {structure} {x} {y} {z}";
    }
    
    @intrinsic
    void placeJigsaw(string pool, string target, int maxDepth, int x, int y, int z) {
        @cmd "place jigsaw {pool} {target} {maxDepth} {x} {y} {z}";
    }
    
    @intrinsic
    void placeJigsawInDimension(string dimension, string pool, string target, int maxDepth, int x, int y, int z) {
        @cmd "execute in {dimension} run place jigsaw {pool} {target} {maxDepth} {x} {y} {z}";
    }
}

namespace Entity {
    // attribute, damage, data (entity), effect, enchant, give, item (entities), kill, ride, summon, tag, teleport
    @intrinsic
    void summon(string entity, int x, int y, int z) {
        @cmd "summon {entity} {x} {y} {z}";
    }
    
    @intrinsic
    void kill(string target) {
        @cmd "kill {target}";
    }
    
    @intrinsic
    void tag(string target, string tag) {
        @cmd "tag {target} add {tag}";
    }
    
    @intrinsic
    void removeTag(string target, string tag) {
        @cmd "tag {target} remove {tag}";
    }
    
    @intrinsic
    void effect(string target, string effect, int duration, int amplifier) {
        @cmd "effect give {target} {effect} {duration} {amplifier}";
    }
    
    @intrinsic
    void clearEffect(string target) {
        @cmd "effect clear {target}";
    }
    
    @intrinsic
    void teleport(string target, int x, int y, int z) {
        @cmd "teleport {target} {x} {y} {z}";
    }
    
    @intrinsic
    void teleportToDimension(string target, string dimension, int x, int y, int z) {
        @cmd "execute in {dimension} run tp {target} {x} {y} {z}";
    }
    
    @intrinsic
    void damage(string target, int amount) {
        @cmd "damage {target} {amount}";
    }
    
    @intrinsic
    void ride(string target, string vehicle) {
        @cmd "ride {target} mount {vehicle}";
    }
    
    @intrinsic
    @returns_command
    int exists(string selector) {
        @cmd "execute if entity {selector}";
    }
    
    @intrinsic
    @store_result_intrinsic
    int existsAt(string executor, string selector) {
        @cmd "execute at {executor} store result storage {__ns}:return value int 1 if entity {selector}";
    }
    
    @intrinsic
    @store_result_intrinsic
    int existsIn(string dimension, string selector) {
        @cmd "execute in {dimension} if entity {selector}";
    }
    
    @intrinsic
    @store_result_intrinsic
    int existsAtBlock(int x, int y, int z, string selector) {
        @cmd "execute at {selector} store result storage {__ns}:return value int 1 positioned {x} {y} {z} if entity {selector}";
    }
}

namespace Player {
    // clear, advancement, experience, gamemode, kick, list, recipe, spectate, team, bossbar
    @intrinsic
    void gamemode(string target, string mode) {
        @cmd "gamemode {mode} {target}";
    }
    
    @intrinsic
    void give(string target, string item, int count) {
        @cmd "give {target} {item} {count}";
    }
    
    @intrinsic
    void clear(string target, string item) {
        @cmd "clear {target} {item}";
    }
    
    @intrinsic
    void kick(string target, string reason) {
        @cmd "kick {target} {reason}";
    }
    
    @intrinsic
    void addExperience(string target, int amount) {
        @cmd "experience add {target} {amount} points";
    }
    
    @intrinsic
    void setExperience(string target, int amount) {
        @cmd "experience set {target} {amount} points";
    }
    
    @intrinsic
    void addLevels(string target, int amount) {
        @cmd "experience add {target} {amount} levels";
    }
    
    @intrinsic
    void advancement(string target, string action, string advancement) {
        @cmd "advancement {action} {target} only {advancement}";
    }
    
    @intrinsic
    void recipe(string target, string action, string recipe) {
        @cmd "recipe {action} {target} {recipe}";
    }
    
    @intrinsic
    void spectate(string target, string entity) {
        @cmd "spectate {entity} {target}";
    }
    
    @intrinsic
    @ref_intrinsic
    void getX(string target, int& x) {
        @cmd "execute store result score {x_player} {x_obj} run data get entity {target} Pos[0] 1";
    }
    
    @intrinsic
    @ref_intrinsic
    void getY(string target, int& y) {
        @cmd "execute store result score {y_player} {y_obj} run data get entity {target} Pos[1] 1";
    }
    
    @intrinsic
    @ref_intrinsic
    void getZ(string target, int& z) {
        @cmd "execute store result score {z_player} {z_obj} run data get entity {target} Pos[2] 1";
    }
    
    @intrinsic
    @ref_intrinsic
    void getXFloat(string target, int& x) {
        @cmd "execute store result score {x_player} {x_obj} run data get entity {target} Pos[0] 1000";
    }
    
    @intrinsic
    @ref_intrinsic
    void getYFloat(string target, int& y) {
        @cmd "execute store result score {y_player} {y_obj} run data get entity {target} Pos[1] 1000";
    }
    
    @intrinsic
    @ref_intrinsic
    void getZFloat(string target, int& z) {
        @cmd "execute store result score {z_player} {z_obj} run data get entity {target} Pos[2] 1000";
    }
    
    @intrinsic
    @ref_intrinsic
    void getAttribute(string target, string attribute, int& value) {
        @cmd "execute store result score {value_player} {value_obj} run attribute {target} {attribute} get";
    }
    
    @intrinsic
    @ref_intrinsic
    void getAttributeFloat(string target, string attribute, int& value) {
        @cmd "execute store result score {value_player} {value_obj} run attribute {target} {attribute} get 1000";
    }
}

