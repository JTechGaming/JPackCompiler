    }
}

namespace Sound {
    // playsound, stopsound
    @intrinsic
    void play(string sound, string target, int x, int y, int z) {
        @cmd "playsound {sound} master {target} {x} {y} {z}";
    }
    
    @intrinsic
    void stop(string target, string sound) {
        @cmd "stopsound {target} * {sound}";
    }
}

namespace Server {
    // schedule, scoreboard, trigger
    @intrinsic
    void schedule(string function, int ticks) {
        @cmd "schedule function {function} {ticks}t";
    }
    
    @intrinsic
    void gamerule(string rule, string value) {
        @cmd "gamerule {rule} {value}";
    }
    
    @intrinsic
    void setScore(string player, string objective, int value) {
        @cmd "scoreboard players set {player} {objective} {value}";
    }
    
    @intrinsic
    @ref_intrinsic  
    void getScore(string player, string objective, int& value) {
        @cmd "execute store result score {value_player} {value_obj} run scoreboard players get {player} {objective}";
    }
    
    @intrinsic
    void addScore(string player, string objective, int amount) {
        @cmd "scoreboard players add {player} {objective} {amount}";
    }
    
    @intrinsic
    void removeScore(string player, string objective, int amount) {
        @cmd "scoreboard players remove {player} {objective} {amount}";
    }
    
    @intrinsic
    void addObjective(string objective, string criteria) {
        @cmd "scoreboard objectives add {objective} {criteria}";
    }
    
    @intrinsic
    void removeObjective(string objective) {
        @cmd "scoreboard objectives remove {objective}";
    }
    
    @intrinsic
    void executeInDimension(string dimension, string function) {
        @cmd "execute in {dimension} run function {function}";
    }
    
    @intrinsic
    void executeAsInDimension(string target, string dimension, string function) {
        @cmd "execute as {target} in {dimension} run function {function}";
    }
    
    @intrinsic
    void executeAsAt(string asTarget, string atTarget, string function) {
        @cmd "execute as {asTarget} at {atTarget} run function {function}";
    }
    
    @intrinsic
    @store_result_intrinsic
    int checkPredicate(string predicate) {
        @cmd "execute store result storage {__ns}:return value int 1 if predicate {predicate}";
    }
    
    @intrinsic
    @store_result_intrinsic
    int checkPredicateAs(string target, string predicate) {
        @cmd "execute as {target} store result storage {__ns}:return value int 1 if predicate {predicate}";
    }
}

namespace NBT {
    @intrinsic
    @ref_intrinsic
    void getEntityData(string target, string path, int& value) {
        @cmd "execute store result score {value_player} {value_obj} run data get entity {target} {path} 1";
    }
    
    @intrinsic
    @ref_intrinsic
    void getEntityDataFloat(string target, string path, int& value) {
        @cmd "execute store result score {value_player} {value_obj} run data get entity {target} {path} 1000";
    }
    
    @intrinsic
    @ref_intrinsic
    void getBlockData(int x, int y, int z, string path, int& value) {
        @cmd "execute store result score {value_player} {value_obj} run data get block {x} {y} {z} {path} 1";
    }
    
    @intrinsic
    void setEntityData(string target, string path, string value) {
        @cmd "data modify entity {target} {path} set value {value}";
    }
    
    @intrinsic
    void setBlockData(int x, int y, int z, string path, string value) {
        @cmd "data modify block {x} {y} {z} {path} set value {value}";
    }
}

namespace Math {
    int abs(int value) {
        if (value < 0) {
            return value * -1;
        }
        return value;
    }
    
    int min(int a, int b) {
        if (a < b) {
            return a;
        }
        return b;
    }
    
    int max(int a, int b) {
        if (a > b) {
            return a;
        }
        return b;
    }
    
    @intrinsic
    @returns_command
    int random(int min, int max) {
        @cmd "random value {min}..{max}";
    }
}