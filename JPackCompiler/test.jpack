@event("minecraft:player_killed_entity", "{\"entity\":{\"type\":\"minecraft:zombie\"}}")
@revoke
void onZombieKill() {
    Chat::say("You killed a zombie!");
    Player::give("@s", "minecraft:rotten_flesh", 1);
}

