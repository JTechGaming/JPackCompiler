@load
void onLoad() {
    // initialize some global state
    World::setBlock(0, 64, 0, "minecraft:gold_block");
    Chat::say("Datapack loaded!");
}

@tick
void onTick() {
    // test basic arithmetic
    int x = 10;
    int y = 20;
    int sum = add(x, y);
    
    // test if/else
    if (sum == 30) {
        Chat::say("Sum is correct!");
    } else {
        Chat::say("Sum is wrong!");
    }
    
    // test while loop
    int counter = 0;
    while (counter < 5) {
        counter = counter + 1;
    }
    
    // test for loop
    int total = 0;
    for (int i = 0; i < 10; i++) {
        total = total + i;
    }
    
    // test nested if
    if (total > 40) {
        if (total > 44) {
            Chat::say("Total is 45!");
        } else {
            Chat::say("Total is between 41 and 44");
        }
    }
    
    // test string variables
    string msg = "{'text':'Hello!','color':'gold','bold':true}";
    Chat::tellRaw("@a", msg);
    
    // test world manipulation
    int bx = 5;
    int by = 64;
    int bz = 5;
    World::setBlock(bx, by, bz, "minecraft:diamond_block");
    World::fill(0, 60, 0, 10, 60, 10, "minecraft:stone");
    
    // test entity stuff
    Entity::summon("minecraft:creeper", 0, 64, 0);
    
    // test math
    int absVal = Math::abs(-5);
    int minVal = Math::min(10, 20);
    int maxVal = Math::max(10, 20);
    int rng = Math::random(1, 100);
    
    // test player stuff
    Player::gamemode("@a", "survival");
    Player::give("@a", "minecraft:diamond", 1);
    
    // test sound
    Sound::play("minecraft:entity.player.levelup", "@a", 0, 64, 0);
    
    // test title
    Chat::title("@a", "Welcome!");
    Chat::subtitle("@a", "This datapack works!");
    
    // test border
    World::setBorderCenter(0, 0);
    World::setBorderDistance(1000);
    
    // test weather
    Server::gamerule("doDaylightCycle", "false");
    Server::gamerule("doWeatherCycle", "false");
}

int add(int a, int b) {
    return a + b;
}

int factorial(int n) {
    if (n == 0) {
        return 1;
    }
    int result = n * factorial(n);
    return result;
}

int clamp(int value, int min, int max) {
    if (value < min) {
        return min;
    }
    if (value > max) {
        return max;
    }
    return value;
}