void addScore(int player, int amount) {
    player = player + amount;
}

@intrinsic
void setBlock(int x, int y, int z, string block) {
    @cmd "setblock {x} {y} {z} {block}";
}

int add(int a, int b) {
    return a + b;
}

@tick
void onTick() {
    int x = 10;
    addScore(x, 5);
    float y = 1.5f;
    if (x == 10) {
        x = x + 1;
    } else {
        x = 0;
    }
    while (x < 100) {
        x = x + 1;
    }
    for (int i = 0; i < 10; i++) {
        int x = i;
    }
    
    int px = 10;
    int py = 64;
    int pz = 10;
    setBlock(px, py, pz, "stone");
    
    int result = add(5, 3);
}

class Player {
public:
    int health = 100;
private:
    float speed = 1.5f;
};